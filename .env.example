# Runtime
GOCLAW_CHANNEL=cli
GOCLAW_WORKSPACE=.
GOCLAW_DATA_DIR=.goclaw
GOCLAW_LOG_LEVEL=info
GOCLAW_MAX_STEPS=8
GOCLAW_BASH_TIMEOUT=10s
GOCLAW_BASH_OUTPUT_LIMIT=65536

# OpenAI-compatible model, used from s01 onward
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT=120s

# Feishu, required when GOCLAW_CHANNEL=feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ALLOWED_USER_IDS=

# Groups are disabled unless both values below are configured
FEISHU_ENABLE_GROUPS=false
FEISHU_ALLOWED_GROUP_IDS=
